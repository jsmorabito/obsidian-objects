From 272eecd25b37a2a52128421a46c131010ec3a3db Mon Sep 17 00:00:00 2001
From: John Morabito <jmorabito10@gmail.com>
Date: Sun, 12 Apr 2026 08:54:16 -0400
Subject: [PATCH] feat: make focus-restore key configurable

The key that exits shortcut mode and restores editor focus was hardcoded
to "i" (a nod to Vim's insert mode). This makes it impossible to use "i"
as the second key in any shortcut sequence, since the keydown handler
intercepts it first and returns action:"focus" instead of passing it to
the sequence matcher.

This change makes the focus key a user-configurable setting (default: "i",
preserving existing behaviour). Users who want "i" in their sequences can
reassign the focus key to any other single character.

Changes:
- KeyboardListener.ts: read `settings.focusKey` instead of hardcoding "i"
- settings.d.ts: add `focusKey: string` to KeySequenceSettings interface
- shortcutsSettingTab.ts: add `focusKey: "i"` default and a single-char
  text input placed directly below "Enter shortcut mode" in the settings UI
---
 src/core/keyboard/KeyboardListener.ts |  5 +++--
 src/shortcutsSettingTab.ts            | 22 ++++++++++++++++++++++
 src/types/settings.d.ts               |  3 +++
 3 files changed, 28 insertions(+), 2 deletions(-)

diff --git a/src/core/keyboard/KeyboardListener.ts b/src/core/keyboard/KeyboardListener.ts
index 681b0e5..42b5125 100644
--- a/src/core/keyboard/KeyboardListener.ts
+++ b/src/core/keyboard/KeyboardListener.ts
@@ -132,8 +132,9 @@ export class KeyboardListener {
 			return triggerResult;
 		}
 
-		// Handle focus mode key ("i")
-		if (hotkeyMode && event.key === "i") {
+		// Handle focus mode key (configurable; skipped if unset)
+		const focusKey = this.plugin.settings.focusKey;
+		if (hotkeyMode && focusKey && event.key === focusKey) {
 			return {
 				shouldProcess: true,
 				action: "focus",
diff --git a/src/shortcutsSettingTab.ts b/src/shortcutsSettingTab.ts
index bfc69fb..8f932e4 100644
--- a/src/shortcutsSettingTab.ts
+++ b/src/shortcutsSettingTab.ts
@@ -58,6 +58,7 @@ export const DEFAULT_KEY_SEQUENCE_SETTINGS: KeySequenceSettings = {
 	editorScopeEnabled: true,
 	editorScopeTrigger: "Alt-s s",
 	editorScopeShowBorder: true,
+	focusKey: "i",
 	firstLoaded: true,
 };
 
@@ -203,6 +204,27 @@ export class ShortcutsSettingTab extends PluginSettingTab {
 					}),
 			);
 
+		new Setting(containerEl)
+			.setName("Focus key")
+			.setDesc(
+				'While in shortcut mode, pressing this key restores focus to the editor (inspired by Vim\'s "i" for insert mode). ' +
+				'Leave blank to disable — useful if you want to use "i" in shortcut sequences and already have another way to exit shortcut mode (e.g. Esc).',
+			)
+			.addText((text) => {
+				text
+					.setPlaceholder("i")
+					.setValue(this.plugin.settings.focusKey ?? "")
+					.onChange((value) => {
+						// Only keep the last typed character so this stays single-key
+						const key = value.slice(-1);
+						text.setValue(key);
+						this.plugin.settings.focusKey = key; // empty string = disabled
+						this.plugin.saveSettings();
+					});
+				text.inputEl.maxLength = 1;
+				text.inputEl.style.width = "3em";
+			});
+
 		new Setting(containerEl)
 			.setName("Show key press visualizer")
 			.setDesc("Show the key presses on screen while in shortcut mode")
diff --git a/src/types/settings.d.ts b/src/types/settings.d.ts
index 581b325..aa267ed 100644
--- a/src/types/settings.d.ts
+++ b/src/types/settings.d.ts
@@ -15,5 +15,8 @@ interface KeySequenceSettings {
 	editorScopeTrigger: string;
 	editorScopeShowBorder: boolean;
 
+	/** Key used to restore editor focus while in shortcut mode (default: "i") */
+	focusKey: string;
+
 	firstLoaded: boolean;
 }
